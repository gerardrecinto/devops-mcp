# Kubernetes
# Defaults to ~/.kube/config if unset.
KUBECONFIG=

# Jenkins
JENKINS_URL=https://jenkins.example.com
JENKINS_USER=your-username
JENKINS_TOKEN=your-api-token

# GitHub Actions
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# AWS
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Or use IAM role / AWS_PROFILE instead of static credentials.
# AWS_PROFILE=default

# Azure
# Uses DefaultAzureCredential (service principal, managed identity, or az login)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# GCP
# Path to a service account JSON, or leave unset to use Application Default Credentials
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT_ID=

# ServiceNow
SNOW_INSTANCE=yourcompany.service-now.com
SNOW_USER=your-username
SNOW_PASSWORD=your-password

# Slack
# Requires scopes: channels:history, chat:write, search:read
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxx

# Microsoft Teams
# For posting alerts: set TEAMS_WEBHOOK_URL (incoming webhook from a Teams channel connector)
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxxx
# For reading channel messages via Graph API: set all three below
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
